# Base URL of the self-hosted OSRM routing engine.
# In local dev with docker-compose this is http://localhost:5000
# On Coolify, point it to the internal OSRM service URL (e.g. http://osrm:5000).
OSRM_URL=http://localhost:5000

# Public site origin — used for SEO canonical / hreflang / sitemap URLs and JSON-LD.
# ⚠ OBLIGATORIU la deploy: setează-l în Coolify ca *Build Variable* (NEXT_PUBLIC_*
# se copt în bundle la `next build`; schimbarea lui la runtime NU are efect).
# Lanțul: Coolify env → docker-compose build args → Dockerfile ARG → next build.
NEXT_PUBLIC_SITE_URL=https://beton.build-time.net

# ── Variabilele de mai jos se aplică DOAR la `npm run dev` / build local. ──
# În imaginea Docker de producție NU sunt wired ca build args, deci rămân pe
# valorile implicite din cod (identice cu cele de aici). Dacă vrei să le poți
# schimba per deploy, adaugă-le ca ARG în Dockerfile + build args în compose.

# Public tile server for the map. Default: CARTO Voyager (soft color).
# Alternatives (no key): .../light_all/... (muted grey, Positron),
# .../light_nolabels/... (no labels), or OpenStreetMap {s}.tile.openstreetmap.org.
NEXT_PUBLIC_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png
NEXT_PUBLIC_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors &copy; CARTO

# Default map center (Chișinău) and zoom.
NEXT_PUBLIC_DEFAULT_LAT=47.0105
NEXT_PUBLIC_DEFAULT_LNG=28.8638
NEXT_PUBLIC_DEFAULT_ZOOM=11
